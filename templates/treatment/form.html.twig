{% extends 'base.html.twig' %}

{% set currentCardImage = form.shortInfo.vars.data and attribute(form.shortInfo.vars.data, 'cardImage') is defined ? attribute(form.shortInfo.vars.data, 'cardImage') : '' %}
{% set currentPageImage = form.vars.data and attribute(form.vars.data, 'imageName') is defined ? attribute(form.vars.data, 'imageName') : '' %}

{% block title %}
	{% if isEdit %}Edit Treatment{% else %}New Treatment
	{% endif %}
{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('adminPanel/site-content-settings-editor.css') }}">
	<style>
		.treatment-form-toolbar {
			position: sticky;
			top: 92px;
			z-index: 20;
			display: flex;
			flex-wrap: wrap;
			gap: 0.75rem;
			align-items: center;
			justify-content: space-between;
			margin: 0 0 1.5rem;
			padding: 1rem;
			border: 1px solid #e4e1dc;
			border-radius: 18px;
			background: rgba(255, 255, 255, 0.92);
			backdrop-filter: blur(10px);
			box-shadow: 0 10px 24px rgba(0, 0, 0, 0.06);
		}

		.treatment-form-tabs {
			display: flex;
			flex: 1 1 720px;
			flex-wrap: wrap;
			gap: 0.65rem;
		}

		.treatment-form-tab {
			padding: 0.65rem 1rem;
			border: 1px solid #d8d3cb;
			border-radius: 999px;
			background: #f6f2ec;
			color: #47413a;
			font: inherit;
			font-size: 0.92rem;
			font-weight: 500;
			cursor: pointer;
			transition: 0.2s ease;
		}

		.treatment-form-tab:hover,
		.treatment-form-tab[aria-selected="true"] {
			border-color: #111;
			background: #111;
			color: #fff;
		}

		.treatment-form-toolbar__save {
			margin: 0 !important;
			background: #0a7500 !important;
			border: solid 1px #0a7500 !important;
			color: white !important;
			white-space: nowrap;
		}

		.treatment-form-toolbar__save:hover {
			background: #000000 !important;
			border: solid 1px #000000 !important;
		}

		@media (max-width: 1024px) {
			.treatment-form-toolbar {
				top: 82px;
			}
		}

		@media (max-width: 780px) {
			.treatment-form-toolbar {
				top: 74px;
				padding: 0.85rem;
			}

			.treatment-form-tab {
				font-size: 0.85rem;
				padding: 0.55rem 0.8rem;
			}
		}
	</style>
{% endblock %}

{% block body %}
	<section class="gray_back treatments-updating-section">
		<div class="treatment-creation-form">
			<h1 class="form-header">
				{% if isEdit %}Edit Treatment{% else %}New Treatment
				{% endif %}
			</h1>

			{% for message in app.flashes('error') %}
				<div class="alert alert-danger">{{ message }}</div>
			{% endfor %}

			{% if app.environment == 'dev' %}
				<h3>Development Mode Messages</h3>
				{% for message in app.flashes('errorDev') %}
					<div class="alert alert-danger">{{ message }}</div>
				{% endfor %}
			{% endif %}


			{{ form_start(form) }}

			<div class="treatment-form-toolbar" data-treatment-tabs data-storage-key="treatment-form-tab:{{ app.request.pathinfo }}">
				<div class="treatment-form-tabs" role="tablist" aria-label="Treatment edit sections">
					<button type="button" class="treatment-form-tab" data-tab-target="basic-information" aria-selected="true">Basic Information</button>
					<button type="button" class="treatment-form-tab" data-tab-target="card-data" aria-selected="false">Card data</button>
					<button type="button" class="treatment-form-tab" data-tab-target="details" aria-selected="false">Details</button>
					<button type="button" class="treatment-form-tab" data-tab-target="duration-recovery" aria-selected="false">Duration &amp; Recovery</button>
					<button type="button" class="treatment-form-tab" data-tab-target="price" aria-selected="false">Price</button>
					<button type="button" class="treatment-form-tab" data-tab-target="questions-answers" aria-selected="false">Questions &amp; Answers</button>
				</div>
				<button type="submit" class="transparent_black_button treatment-form-toolbar__save">Save Treatment</button>
			</div>

			{# === Basic info card === #}
			<div class="card-block" data-treatment-tab-panel="basic-information">
				<h3 class="card-title">Basic Information</h3>
				<div class="form-row">
					<div class="half">
						{{ form_row(form.name, {
						'attr': {
							'class': 'form-control' ~ (form.name.vars.errors|length > 0 ? ' error' : ''),
							'placeholder': 'Enter treatment name',
							'required': 'required'
						}
					}) }}
					</div>
					<div class="half">
						{{ form_row(form.category) }}
					</div>
				</div>
				<div class="file-upload">
					<label for="treatment_image_card" class="file-label">
						<span class="file-button">📁 Card Image</span>
						<span class="file-name">{{ currentCardImage ?: 'No file chosen' }}</span>
					</label>
					{{ form_widget(form.image_card, {'attr': {
						'class': 'file-input',
						'data-treatment-file-preview': '1',
						'data-current-file': currentCardImage,
						'data-download-prefix': '/' ~ treatment_card_img_base_dir
					}}) }}
					<p class="file-hint">Use a narrow format, like Instagram portrait (e.g. 4:5).</p>
					{% if currentCardImage %}
						<div class="site-content-current-preview">
							<div class="site-content-preview-title">Current image</div>
							<div class="site-content-preview-wrap">
								<a href="{{ asset(treatment_card_img_base_dir ~ currentCardImage) }}" download target="_blank" rel="noopener">Download current</a>
								<img src="{{ asset(treatment_card_img_base_dir ~ currentCardImage) }}" alt="Current card image preview">
							</div>
						</div>
					{% endif %}
					<div class="site-content-next-preview" hidden></div>
				</div>

				<div class="file-upload">
					<label for="treatment_image_page" class="file-label">
						<span class="file-button">📁 Page image</span>
						<span class="file-name">{{ currentPageImage ?: 'No file chosen' }}</span>
					</label>
					{{ form_widget(form.image_page, {'attr': {
						'class': 'file-input',
						'data-treatment-file-preview': '1',
						'data-current-file': currentPageImage,
						'data-download-prefix': '/' ~ treatment_page_img_base_dir
					}}) }}
					<p class="file-hint">Use a wide format, suitable for page headers (e.g. 16:9).</p>
					{% if currentPageImage %}
						<div class="site-content-current-preview">
							<div class="site-content-preview-title">Current image</div>
							<div class="site-content-preview-wrap">
								<a href="{{ asset(treatment_page_img_base_dir ~ currentPageImage) }}" download target="_blank" rel="noopener">Download current</a>
								<img src="{{ asset(treatment_page_img_base_dir ~ currentPageImage) }}" alt="Current page image preview">
							</div>
						</div>
					{% endif %}
					<div class="site-content-next-preview" hidden></div>
				</div>

			</div>

			{# === Short Info card === #}
			<div class="card-block" data-treatment-tab-panel="card-data" style="display:none;">
				<h3 class="card-title">Card data</h3>
				<div class="full">
					{{ form_row(form.shortInfo.title, {
						'attr': {
							'class': 'form-control' ~ (form.shortInfo.title.vars.errors|length > 0 ? ' error' : ''),
							'placeholder': 'Enter short title',
							'required': 'required'
						}
					}) }}
					<p class="input-hint">A short phrase to describe the benefit (e.g. Add volume. Improve contours.).</p>
				</div>
				<div class="full">
					{{ form_row(form.shortInfo.description, {
						'attr': {
							'class': 'form-control' ~ (form.shortInfo.description.vars.errors|length > 0 ? ' error' : ''),
							'placeholder': 'Enter treatment description',
							'required': 'required'
						}
					}) }}
					<p class="input-hint">A short description of the treatment.</p>
				</div>

			</div>

			<div class="card-block" data-treatment-tab-panel="details" style="display:none;">
				<h3 class="card-title">Details</h3>
				<div class="full">
					{{ form_row(form.fullDescription, {
						'attr': {
							'class': 'form-control' ~ (form.fullDescription.vars.errors|length > 0 ? ' error' : ''),
							'placeholder': 'Enter full description'
						}
					}) }}
					<p class="input-hint">A detailed description of the treatment.</p>
				</div>
				<div class="full">
					{{ form_row(form.discomfortLevel, {
						'attr': {
							'class': 'form-control' ~ (form.discomfortLevel.vars.errors|length > 0 ? ' error' : '')
						}
					}) }}
					<p class="input-hint">How much discomfort does the procedure cause?</p>
				</div>
			</div>

			{# === Duration & Recovery card === #}
			<div class="card-block" data-treatment-tab-panel="duration-recovery" style="display:none;">
				<h3 class="card-title">Duration & Recovery</h3>
				<div class="form-row">
					{{ form_row(form.time.hours, {
						'attr': {
							'placeholder': 'Specify hours',
							'class': 'form-control' ~ (form.time.hours.vars.errors|length > 0 ? ' error' : ''),
							'min': 0,
							'max': 23,
							'value': form.time.hours.vars.value ?: 0
						}
					}) }}
					{{ form_row(form.time.minutes, {
						'attr': {
							'class': 'form-control' ~ (form.time.minutes.vars.errors|length > 0 ? ' error' : ''),
							'min': 0,
							'max': 59,
							'value': form.time.minutes.vars.value ?: 0
						}
					}) }}
				</div>
				<p class="input-hint">When setting the number of hours to 0, only minutes are displayed.</p>
				<div class="form-row">
					{{ form_row(form.recover.min, {
						'attr': {
							'class': 'form-control' ~ (form.recover.min.vars.errors|length > 0 ? ' error' : ''),
							'min': 0,
							'value': form.recover.min.vars.value ?: 0
						}
					}) }}
					{{ form_row(form.recover.max, {
						'attr': {
							'class': 'form-control' ~ (form.recover.max.vars.errors|length > 0 ? ' error' : ''),
							'min': 0,
							'value': form.recover.max.vars.value ?: 0
						}
					}) }}
					{{ form_row(form.recover.period, {
						'attr': {
							'class': 'form-control' ~ (form.recover.period.vars.errors|length > 0 ? ' error' : ''),
						}
					}) }}
				</div>
				<span class="input-hint">
					<ul>
						<li>If both values ​​are empty (0–0) → the recovery period is considered minimal.</li>
						<li>If only the "To" field is filled in → an approximate time is specified (e.g., ~10 days).</li>
						<li>If only the "From" field is filled in → the period "from ..." is specified (e.g., `from 5 days").</li>
						<li>If both fields are filled in → a range is specified (e.g., from 5 to 10 days).</li>
					</ul>
				</span>
			</div>


			{# === Price card === #}
			<div class="card-block" data-treatment-tab-panel="price" style="display:none;">
				<h3 class="card-title">Price</h3>
				{{ form_row(form.price.isFixed, { 'row_attr': {'class': 'form-checkbox'} }) }}
				<div class="form-row">
					<div id="price-type-row" {% if form.price.isFixed.vars.value %} style="display:none" {% endif %}>
						{{ form_row(form.price.priceType) }}
					</div>
					{{ form_row(form.price.price, {
						'attr': {
							'class': 'form-control' ~ (form.price.price.vars.errors|length > 0 ? ' error' : ''),
							'min': 0,
							'value': form.price.price.vars.value ?: 0
						}
					}) }}
				</div>
				<span class="input-hint">
					<ul>
						<li>If price is fixed → the exact price is displayed (e.g., £500).</li>
						<li>Otherwise → the following pattern is displayed [from PRICE per TYPE] (e.g., from £300 per course).</li>
					</ul>
				</span>
			</div>

			{# === Questions card === #}
			<div class="card-block" data-treatment-tab-panel="questions-answers" style="display:none;">
				<h3 class="card-title">Questions & Answers</h3>
					<div id="questions-container" data-prototype="{{ form_widget(form.questions.vars.prototype)|e('html_attr') }}">
						{% for questionForm in form.questions %}
							<div class="question-block">
								{{ form_widget(questionForm) }}
								<button type="button" class="remove-question">Remove</button>
							</div>
						{% endfor %}
					</div>
					<button class="transparent_black_button" type="button" id="add-question">Add Question</button>
			</div>

			{% if form.questions is empty %}
				<div style="display: none;">
					{{ form_row(form.questions) }}
				</div>
			{% endif %}

			{{ form_end(form) }}
		</div>
	</section>

{% endblock %}

{% block javascripts %}
	<script>
		window.CKEDITOR_BASEPATH = '{{ asset('ckeditor4') }}/';
	</script>
	<script src="{{ asset('ckeditor4/ckeditor.js') }}"></script>
	<script src="{{ asset('js/treatments.js') }}"></script>
{% endblock %}
